                        Background="#fee2e2" Foreground="#b91c1c" 
                        BorderThickness="0"/>
                    <local:MyTextButton Text="点击下载"  FontWeight="Medium" Padding="10,4"
                        EventType="打开网页" EventData="https://pan.quark.cn/s/05564dc9f7bf"
                        Background="#d1fae5" Foreground="#065f46" 
                        BorderThickness="0"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</local:MyCard>


