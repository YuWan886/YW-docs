                        BorderThickness="0"/>
                    <local:MyTextButton Text="查看原址"  FontWeight="Medium" Padding="10,4" Margin="0,0,8,0"
                        EventType="打开网页" EventData="https://www.planetminecraft.com/project/speed-builders-1-0/"
                        Background="#fee2e2" Foreground="#b91c1c" 
                        BorderThickness="0"/>
                    <local:MyTextButton Text="点击下载"  FontWeight="Medium" Padding="10,4"
                        EventType="打开网页" EventData="https://pan.quark.cn/s/29ea29147886"
                        Background="#d1fae5" Foreground="#065f46" 
                        BorderThickness="0"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</local:MyCard>


